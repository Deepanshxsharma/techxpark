# ═══════════════════════════════════════════════════
#  TechXPark — Flutter + Firebase .gitignore
# ═══════════════════════════════════════════════════

# ── Flutter & Dart ────────────────────────────────
.dart_tool/
.packages
.pub-cache/
.pub/
build/
*.iml
*.log

# ── Android ───────────────────────────────────────
android/.gradle/
android/local.properties
android/key.properties
android/app/build/
**/android/**/gradle-wrapper.jar
.gradle/

# ── iOS ───────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner/GeneratedPluginRegistrant.*

# ── IDE ───────────────────────────────────────────
.idea/
.vscode/
.cursor/
*.swp
*.swo

# ── macOS / Windows / Linux ───────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
*.tmp

# ── Firebase ──────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log

# ── Cloud Functions ───────────────────────────────
node_modules/
**/node_modules/

# ── Secrets — NEVER commit ────────────────────────
.env
.env.*
**/.env
**/.env.*
*.keystore
**/key.properties
**/serviceAccountKey.json

# ── Seed & Test Data ─────────────────────────────
gatex-seed/
users.json
make_owner.js
tmp_import.txt

# ── Misc build outputs ───────────────────────────
dist/
**/dist/
coverage/
**/.vite/

# ── Flutter generated ────────────────────────────
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# ── Root screenshots (not needed in repo) ────────
dashboard_app.png
dashboard_app_v2.png
.github/
