rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // TECHXPARK CORE COLLECTIONS
    // ═══════════════════════════════════════════

    match /users/{userId} {
      allow read, write: if request.auth != null;

      // Subcollections (vehicles, etc.) — owner can read/write
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Parking locations — public read so all users see lots
    match /parking_locations/{lotId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Subcollections (slots, floors, etc.)
      match /{subcollection=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Legacy alias — keep in case any old data exists
    match /parkingLots/{lotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }

    // Support / inbox conversations
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Notifications — users can read their own, system can write
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Reviews — public read, auth write
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // GODREJ BKC COLLECTIONS
    // ═══════════════════════════════════════════

    // Public read for request tracking (employee uses token link)
    match /godrej_requests/{requestId} {
      allow read: if true;
      allow write: if request.auth != null || resource == null;
    }

    // Zones - public read for queue display
    match /godrej_zones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Lifters - public read for status display
    match /godrej_lifters/{lifterId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Employees - auth only
    match /godrej_employees/{empId} {
      allow read, write: if request.auth != null;
    }

    // Notifications - auth only
    match /godrej_notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Settings - auth only
    match /godrej_settings/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
