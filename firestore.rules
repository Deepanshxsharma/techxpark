rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ─────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── USERS ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Users cannot modify their own role, activeBookings, or maxActiveBookings
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'maxActiveBookings']))
        || isAdmin();
      allow delete: if false;

      match /vehicles/{vehicleId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── PARKING LOCATIONS ────────────────────────────────────────────────
    match /parking_locations/{parkingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();

      match /slots/{slotId} {
        allow read: if isAuthenticated();
        // Booking transactions update slot availability
        allow update: if isAuthenticated();
        allow create, delete: if isAdmin();
      }
    }

    // ─── BOOKINGS (HARDENED) ──────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Read: owner, admin, or any authenticated user (only to check availability of active/upcoming)
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || resource.data.status in ['active', 'upcoming']);

      // Create: authenticated user, must set own userId
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        // Must include required fields
        && request.resource.data.keys().hasAll([
            'userId', 'parkingId', 'slotId', 'startTime', 'endTime', 'status'
           ])
        // Status must be 'active' on creation
        && request.resource.data.status == 'active';

      // Update: owner can only cancel; admin can do anything
      allow update: if isAuthenticated() && (
        // Admin can update anything
        isAdmin()
        ||
        // Owner can only change status to 'cancelled', and add cancelledAt
        (resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'cancelledAt', 'endTime', 'hours', 'extended', 'reviewed'])
          // Cannot modify protected fields
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.parkingId == resource.data.parkingId
          && request.resource.data.slotId == resource.data.slotId
          && request.resource.data.startTime == resource.data.startTime
          && request.resource.data.createdAt == resource.data.createdAt
        )
      );

      // Never allow client-side delete
      allow delete: if false;
    }

    // ─── PAYMENTS ─────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ─── NOTIFICATIONS ────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ─── REVIEWS ──────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immutable
    }

    // ─── CONVERSATIONS ───────────────────────────────────────────────────
    match /conversations/{conversationId} {
      // Users can only read/write conversations where their UID is in the participants array
      allow read: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || isAdmin());
      allow update: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || isAdmin());
      // On create, the creator must be in the participants array
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // Only conversation participants can read/write messages
        allow read, write: if isAuthenticated() && 
          (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());
      }
    }

    // ─── SUPPORT CHATS ───────────────────────────────────────────────────
    match /support_chats/{chatId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ─── GATE REQUESTS ───────────────────────────────────────────────────
    match /gate_requests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // ─── BOOKING AUDIT LOG (Fraud Detection) ─────────────────────────────
    match /booking_audit_log/{logId} {
      // Anyone can create (app logs failed attempts)
      allow create: if isAuthenticated();
      // Only admin can read audit logs
      allow read: if isAdmin();
      // Never update or delete
      allow update, delete: if false;
    }

    // ─── ADMIN USERS ─────────────────────────────────────────────────────
    match /admin_users/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Manual setup only
    }
  }
}
