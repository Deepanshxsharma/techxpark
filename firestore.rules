rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.role == role;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true || hasRole('admin'));
    }

    function isOwner() {
      return signedIn()
        && (isAdmin() || hasRole('owner'));
    }

    function isConversationParticipant(conversation) {
      return signedIn()
        && conversation.participants is list
        && request.auth.uid in conversation.participants;
    }

    function ownsExistingUserField() {
      return signedIn()
        && resource.data.userId is string
        && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingUserField() {
      return signedIn()
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid;
    }

    function protectsUserRoleFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'banned',
        'blocked',
        'accessStatus',
        'assignedLotId',
        'isVerified',
      ]);
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin() || isOwner();
      allow create: if isSelf(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('role' in request.resource.data) || request.resource.data.role == 'customer')
        && (!('banned' in request.resource.data) || request.resource.data.banned == false)
        && (!('blocked' in request.resource.data) || request.resource.data.blocked == false);
      allow update: if isAdmin() || (isSelf(userId) && protectsUserRoleFields());
      allow delete: if isAdmin() || isSelf(userId);

      match /{subcollection=**} {
        allow read, write: if isSelf(userId) || isAdmin();
      }
    }

    match /parking_locations/{lotId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner();

      match /{subcollection=**} {
        allow read: if true;
        allow write: if isAdmin() || isOwner();
      }
    }

    match /parkingLots/{lotId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || isOwner() || ownsExistingUserField();
      allow create: if isAdmin() || ownsIncomingUserField();
      allow update: if isAdmin() || ownsExistingUserField();
      allow delete: if isAdmin();
    }

    match /booking_audit_log/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read, update, delete: if isAdmin()
        || isConversationParticipant(resource.data);
      allow create: if isAdmin()
        || isConversationParticipant(request.resource.data);

      match /messages/{messageId} {
        allow read, create, update: if isAdmin()
          || isConversationParticipant(
            get(/databases/$(database)/documents/conversations/$(conversationId)).data
          );
        allow delete: if isAdmin();
      }
    }

    match /notifications/{notifId} {
      allow read, update, delete: if isAdmin() || ownsExistingUserField();
      allow create: if isAdmin() || ownsIncomingUserField();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || ownsExistingUserField();
    }

    match /godrej_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || isOwner();
    }

    match /godrej_zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner();
    }

    match /godrej_lifters/{lifterId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner();
    }

    match /godrej_employees/{empId} {
      allow read, write: if isAdmin() || isOwner();
    }

    match /godrej_notifications/{notifId} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin() || isOwner();
    }

    match /godrej_settings/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin() || isOwner();
    }
  }
}
